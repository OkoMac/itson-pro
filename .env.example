# ─── Itson-Pro Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to run with local seed data (no backend required).
# Leave blank or set to "false" to use real Supabase + API.
VITE_DEMO_MODE=true

# ── Supabase (required when VITE_DEMO_MODE=false) ─────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── REST API (optional — used if Supabase is not configured) ──────────────────
# Base URL for your own backend API (e.g. https://api.itson.pro)
VITE_API_URL=

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Itson-Pro
VITE_APP_VERSION=1.0.0
